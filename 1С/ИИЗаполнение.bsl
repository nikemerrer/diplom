// МОДУЛЬ ФОРМЫ (исправленная версия)
// Кнопки:
// - "Заполнить ИИ" -> выбор файла -> POST /api/jobs (JSON+base64) -> JobIdИИ
// - "Получить результат ИИ" -> POST /api/jobs/result {job_id} -> заполнение реквизитов документа
//
// Логика:
// 1) В 1С записываем ТОЛЬКО onec_fields:
//    - Заголовок
//    - Организация (организация_заказчик)
//    - Подразделение
//    - СубъектыПерсональныхДанных
// 2) Всё остальное из extra_findings только выводим сообщениями.
//
// Исправления:
// - нельзя запускать второй файл на той же форме, пока не завершена текущая job
// - JobIdИИ очищается после done/error
// - поиск подразделения больше не падает, если в конфигурации нет Справочники.Подразделения

&НаКлиенте
Перем JobIdИИ;

&НаКлиенте
Процедура ЛогК(Текст)
	Сообщить("[ИИ][К] " + Текст);
КонецПроцедуры

&НаСервере
Процедура ЛогС(Текст)
	Сообщить("[ИИ][С] " + Текст);
КонецПроцедуры

// ======================================================
// 1) ДОБАВЛЕНИЕ КНОПОК НА ФОРМУ
// ======================================================
&НаСервере
Процедура Расш1_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)

	Команда1 = РаботаСФормами.ДобавитьКоманду(ЭтаФорма,
		"КомандаЗаполнитьИИ",
		"Заполнить ИИ",
		"Заполнить ИИ");
	РаботаСФормами.ДобавитьКнопку(ЭтаФорма,
		"ЗаполнитьИИ",
		Элементы.ГруппаОсновнаяКомПанель,
		"КомандаЗаполнитьИИ");
	Команда1.Действие = "Подключаемый_ЗаполнениеСтороннимСервисом";

	Команда2 = РаботаСФормами.ДобавитьКоманду(ЭтаФорма,
		"КомандаПолучитьРезультатИИ",
		"Получить результат ИИ",
		"Получить результат ИИ");
	РаботаСФормами.ДобавитьКнопку(ЭтаФорма,
		"ПолучитьРезультатИИ",
		Элементы.ГруппаОсновнаяКомПанель,
		"КомандаПолучитьРезультатИИ");
	Команда2.Действие = "Подключаемый_ПолучитьРезультатИИ";

КонецПроцедуры

// ======================================================
// 2) КЛИЕНТ: ВЫБОР ФАЙЛА
// ======================================================
&НаКлиенте
Процедура Подключаемый_ЗаполнениеСтороннимСервисом(Команда)

	Если ЗначениеЗаполнено(JobIdИИ) Тогда
		Сообщить("На этой форме уже есть активная задача ИИ. Сначала получите результат по текущей задаче.");
		Возврат;
	КонецЕсли;

	Фильтр = "Документы (*.pdf;*.doc;*.docx;*.rtf;*.txt)|*.pdf;*.doc;*.docx;*.rtf;*.txt|Все файлы (*.*)|*.*|";	
	Парам = Новый ПараметрыДиалогаПомещенияФайлов("Выберите файл", Ложь, Фильтр);
	Опов = Новый ОписаниеОповещения("ПослеВыбораФайлаИИ", ЭтаФорма);

	НачатьПомещениеФайлаНаСервер(Опов,,,, Парам, ЭтаФорма.УникальныйИдентификатор);

КонецПроцедуры

&НаКлиенте
Процедура ПослеВыбораФайлаИИ(Результат, ДопПараметры) Экспорт

	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Описание = ?(ТипЗнч(Результат) = Тип("Массив"), Результат[0], Результат);

	Адрес = "";
	ИмяФайла = "";

	Попытка Адрес = Описание.Адрес; Исключение КонецПопытки;
	Попытка ИмяФайла = Описание.ИмяФайла; Исключение КонецПопытки;

	Если ПустаяСтрока(Адрес) Тогда
		Сообщить("Не удалось получить адрес временного хранилища.");
		Возврат;
	КонецЕсли;

	Если ПустаяСтрока(ИмяФайла) Тогда
		ИмяФайла = "uploaded.bin";
	КонецЕсли;

	Попытка
		JobId = ВызватьAPI_CreateJob(Адрес, ИмяФайла);
	Исключение
		Сообщить("Ошибка создания job: " + ОписаниеОшибки());
		Возврат;
	КонецПопытки;

	Если ПустаяСтрока(JobId) Тогда
		Сообщить("API не вернул job_id.");
		Возврат;
	КонецЕсли;

	JobIdИИ = JobId;
	Сообщить("Задача создана. JobId: " + JobId + ". Нажмите 'Получить результат ИИ'.");

КонецПроцедуры

// ======================================================
// 3) КЛИЕНТ: КНОПКА "ПОЛУЧИТЬ РЕЗУЛЬТАТ ИИ"
// ======================================================
&НаКлиенте
Процедура Подключаемый_ПолучитьРезультатИИ(Команда)

	Если Не ЗначениеЗаполнено(JobIdИИ) Тогда
		Сообщить("Нет JobId. Сначала нажмите 'Заполнить ИИ'.");
		Возврат;
	КонецЕсли;

	Попытка
		Данные = ПолучитьРезультатJob_Post(JobIdИИ);
	Исключение
		Сообщить("Ошибка получения результата: " + ОписаниеОшибки());
		Возврат;
	КонецПопытки;

	Если Данные = Неопределено Тогда
		Возврат;
	КонецЕсли;

	ЗаполнитьПоляИзJson(Данные);
	JobIdИИ = "";
	Сообщить("Результат ИИ применён.");

КонецПроцедуры

// ======================================================
// 4) ЗАПОЛНЕНИЕ ПОЛЕЙ ИЗ JSON
// ======================================================
&НаКлиенте
Процедура ЗаполнитьПоляИзJson(Данные)

	Если ТипЗнч(Данные) <> Тип("Структура") Тогда
		Сообщить("Некорректный ответ ИИ (ожидалась Структура).");
		Возврат;
	КонецЕсли;

	Поля1С = Неопределено;
	ДопНаходки = Неопределено;
	Мета = Неопределено;

	Если Данные.Свойство("onec_fields", Поля1С) = Ложь Тогда
		Поля1С = Данные;
	КонецЕсли;

	Данные.Свойство("extra_findings", ДопНаходки);
	Данные.Свойство("_meta", Мета);

	Если ТипЗнч(Поля1С) <> Тип("Структура") Тогда
		Сообщить("В ответе ИИ отсутствует блок onec_fields.");
		Возврат;
	КонецЕсли;

	// 1. Заголовок
	Заголовок = ПолучитьСтрокуИзСтруктуры(Поля1С, "заголовок");
	Если Не ПустаяСтрока(Заголовок) Тогда
		Объект.Заголовок = Заголовок;
		Сообщить("ИИ: заголовок извлечен -> " + Заголовок);
	Иначе
		Сообщить("ИИ: заголовок не найден.");
	КонецЕсли;

	// 2. Организация = организация-заказчик
	ИмяОрганизации = ПолучитьСтрокуИзСтруктуры(Поля1С, "организация_заказчик");
	Если Не ПустаяСтрока(ИмяОрганизации) Тогда
		ОрганизацияСсылка = НайтиОрганизациюПоНаименованиюСервер(ИмяОрганизации);
		Если ЗначениеЗаполнено(ОрганизацияСсылка) Тогда
			Объект.Организация = ОрганизацияСсылка;
			Сообщить("ИИ: организация найдена -> " + ИмяОрганизации);
		Иначе
			Сообщить("ИИ: организация не найдена в справочнике -> " + ИмяОрганизации);
		КонецЕсли;
	Иначе
		Сообщить("ИИ: организация-заказчик не найдена в документе.");
	КонецЕсли;

	// 3. Подразделение
	ИмяПодразделения = ПолучитьСтрокуИзСтруктуры(Поля1С, "подразделение");
	Если Не ПустаяСтрока(ИмяПодразделения) Тогда

		ПодразделениеСсылка = Неопределено;
		Попытка
			ПодразделениеСсылка = НайтиПодразделениеПоНаименованиюСервер(ИмяПодразделения);
		Исключение
			Сообщить("ИИ: ошибка поиска подразделения -> " + ОписаниеОшибки());
		КонецПопытки;

		Если ЗначениеЗаполнено(ПодразделениеСсылка) Тогда
			Объект.Подразделение = ПодразделениеСсылка;
			Сообщить("ИИ: подразделение найдено -> " + ИмяПодразделения);
		Иначе
			Сообщить("ИИ: подразделение не найдено в справочнике -> " + ИмяПодразделения);
		КонецЕсли;
	Иначе
		Сообщить("ИИ: подразделение не найдено в документе.");
	КонецЕсли;

	// 4. Физические лица -> табличная часть СубъектыПерсональныхДанных
	МассивФизлиц = ПолучитьМассивИзСтруктуры(Поля1С, "физические_лица");
	КолДобавлено = 0;
	КолНеНайдено = 0;

	Для каждого ФИО Из МассивФизлиц Цикл
		ФИОСтрокой = Строка(ФИО);
		Если ПустаяСтрока(ФИОСтрокой) Тогда
			Продолжить;
		КонецЕсли;

		ФизЛицоСсылка = НайтиФизЛицоПоНаименованиюСервер(ФИОСтрокой);
		Если ЗначениеЗаполнено(ФизЛицоСсылка) Тогда
			Если Не УжеЕстьФизЛицоВТаблице(ФизЛицоСсылка) Тогда
				НоваяСтрока = Объект.СубъектыПерсональныхДанных.Добавить();
				НоваяСтрока.ФизическоеЛицо = ФизЛицоСсылка;
				КолДобавлено = КолДобавлено + 1;
			Иначе
				Сообщить("ИИ: физлицо уже есть в табличной части -> " + ФИОСтрокой);
			КонецЕсли;
		Иначе
			КолНеНайдено = КолНеНайдено + 1;
			Сообщить("ИИ: физлицо не найдено в справочнике -> " + ФИОСтрокой);
		КонецЕсли;
	КонецЦикла;

	Сообщить("ИИ: добавлено физлиц: " + Строка(КолДобавлено));
	Если КолНеНайдено > 0 Тогда
		Сообщить("ИИ: не найдено физлиц в справочнике: " + Строка(КолНеНайдено));
	КонецЕсли;

	// 5. Дополнительные сущности только сообщениями
	Если ТипЗнч(ДопНаходки) = Тип("Структура") Тогда
		ПоказатьДополнительныеНаходкиИИ(ДопНаходки);
	КонецЕсли;

	Если ТипЗнч(Мета) = Тип("Структура") Тогда
		ПоказатьМетуИИ(Мета);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПоказатьДополнительныеНаходкиИИ(ДопНаходки)

	Сообщить("ИИ: дополнительные сущности из документа:");

	ПоказатьЕслиЕсть(ДопНаходки, "вид_документа", "  - вид документа");
	ПоказатьЕслиЕсть(ДопНаходки, "номер_документа", "  - номер документа");
	ПоказатьЕслиЕсть(ДопНаходки, "дата_документа", "  - дата документа");
	ПоказатьЕслиЕсть(ДопНаходки, "город", "  - город");
	ПоказатьЕслиЕсть(ДопНаходки, "организация_исполнитель", "  - организация-исполнитель");
	ПоказатьЕслиЕсть(ДопНаходки, "контрагент", "  - контрагент");
	ПоказатьЕслиЕсть(ДопНаходки, "объект_наименование", "  - объект");
	ПоказатьЕслиЕсть(ДопНаходки, "объект_адрес", "  - адрес объекта");
	ПоказатьЕслиЕсть(ДопНаходки, "стоимость_услуг", "  - стоимость услуг");
	ПоказатьЕслиЕсть(ДопНаходки, "режим_охраны", "  - режим охраны");
	ПоказатьЕслиЕсть(ДопНаходки, "лицензия", "  - лицензия");

	Если ДопНаходки.Свойство("подписанты") Тогда
		СписокПодписантов = ДопНаходки["подписанты"];
		Если ТипЗнч(СписокПодписантов) = Тип("Массив") Тогда
			Для каждого СтрПодписанта Из СписокПодписантов Цикл
				Если ТипЗнч(СтрПодписанта) = Тип("Структура") Тогда
					ФиоПодписанта = ПолучитьСтрокуИзСтруктуры(СтрПодписанта, "фио");
					РольПодписанта = ПолучитьСтрокуИзСтруктуры(СтрПодписанта, "роль");
					Если Не ПустаяСтрока(ФиоПодписанта) Тогда
						Сообщить("  - подписант: " + ФиоПодписанта + ?(ПустаяСтрока(РольПодписанта), "", " (" + РольПодписанта + ")"));
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПоказатьМетуИИ(Мета)
	Движок = ПолучитьСтрокуИзСтруктуры(Мета, "engine");
	Модель = ПолучитьСтрокуИзСтруктуры(Мета, "model_id");
	КолСущностей = ПолучитьСтрокуИзСтруктуры(Мета, "entity_count");

	Если Не ПустаяСтрока(Движок) Или Не ПустаяСтрока(Модель) Или Не ПустаяСтрока(КолСущностей) Тогда
		Сообщить("ИИ: движок=" + Движок + "; модель=" + Модель + "; найдено сущностей=" + КолСущностей);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьЕслиЕсть(СтруктураДанных, ИмяСвойства, Заголовок)
	ЗначениеСтрокой = ПолучитьСтрокуИзСтруктуры(СтруктураДанных, ИмяСвойства);
	Если Не ПустаяСтрока(ЗначениеСтрокой) Тогда
		Сообщить(Заголовок + ": " + ЗначениеСтрокой);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Функция ПолучитьСтрокуИзСтруктуры(Данные, ИмяСвойства)
	Значение = "";
	Если ТипЗнч(Данные) = Тип("Структура") Тогда
		Если Данные.Свойство(ИмяСвойства, Значение) Тогда
			Если Значение <> Неопределено Тогда
				Возврат Строка(Значение);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	Возврат "";
КонецФункции

&НаКлиенте
Функция ПолучитьМассивИзСтруктуры(Данные, ИмяСвойства)
	Значение = Неопределено;
	Если ТипЗнч(Данные) = Тип("Структура") Тогда
		Если Данные.Свойство(ИмяСвойства, Значение) Тогда
			Если ТипЗнч(Значение) = Тип("Массив") Тогда
				Возврат Значение;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	Возврат Новый Массив;
КонецФункции

&НаКлиенте
Функция УжеЕстьФизЛицоВТаблице(ФизЛицоСсылка)
	Для каждого Стр Из Объект.СубъектыПерсональныхДанных Цикл
		Если Стр.ФизическоеЛицо = ФизЛицоСсылка Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	Возврат Ложь;
КонецФункции

// ======================================================
// 5) ПОИСК ССЫЛОК В СПРАВОЧНИКАХ
// ======================================================
&НаСервере
Функция НайтиОрганизациюПоНаименованиюСервер(Наименование) Экспорт
	Если ПустаяСтрока(Наименование) Тогда
		Возврат Неопределено;
	КонецЕсли;
	Возврат Справочники.Организации.НайтиПоНаименованию(Наименование);
КонецФункции

&НаСервере
Функция НайтиПодразделениеПоНаименованиюСервер(Наименование) Экспорт

	Если ПустаяСтрока(Наименование) Тогда
		Возврат Неопределено;
	КонецЕсли;

	Если Метаданные.Справочники.Найти("Подразделения") <> Неопределено Тогда
		Возврат Справочники.Подразделения.НайтиПоНаименованию(Наименование);
	КонецЕсли;

	Если Метаданные.Справочники.Найти("ПодразделенияОрганизаций") <> Неопределено Тогда
		Возврат Справочники.ПодразделенияОрганизаций.НайтиПоНаименованию(Наименование);
	КонецЕсли;

	Если Метаданные.Справочники.Найти("СтруктураПредприятия") <> Неопределено Тогда
		Возврат Справочники.СтруктураПредприятия.НайтиПоНаименованию(Наименование);
	КонецЕсли;

	ЛогС("Справочник подразделений в конфигурации не найден.");
	Возврат Неопределено;

КонецФункции

&НаСервере
Функция НайтиФизЛицоПоНаименованиюСервер(Наименование) Экспорт
	Если ПустаяСтрока(Наименование) Тогда
		Возврат Неопределено;
	КонецЕсли;
	Возврат Справочники.ФизическиеЛица.НайтиПоНаименованию(Наименование);
КонецФункции

// ======================================================
// 6) JOB API: CREATE + RESULT(POST)
// ======================================================
&НаСервере
Функция ВызватьAPI_CreateJob(АдресВремХранилища, ИмяФайла) Экспорт

	Данные = ПолучитьИзВременногоХранилища(АдресВремХранилища);
	Если ТипЗнч(Данные) = Тип("ХранилищеЗначения") Тогда
		Двоичные = Данные.Получить();
	Иначе
		Двоичные = Данные;
	КонецЕсли;

	Если Двоичные = Неопределено Тогда
		Возврат "";
	КонецЕсли;

	Base64 = Base64Строка(Двоичные);
	Base64 = СтрЗаменить(Base64, Символы.ПС, "");
	Base64 = СтрЗаменить(Base64, Символы.ВК, "");
	Base64 = СтрЗаменить(Base64, Символы.Таб, "");
	Base64 = СтрЗаменить(Base64, " ", "");

	Тело = Новый Структура;
	Тело.Вставить("filename", ИмяФайла);
	Тело.Вставить("content_base64", Base64);

	Meta = Новый Структура;
	Попытка
		Meta.Вставить("user_id", Строка(Пользователи.ТекущийПользователь().Наименование));
	Исключение
		Meta.Вставить("user_id", "");
	КонецПопытки;
	Тело.Вставить("meta", Meta);

	Запись = Новый ЗаписьJSON;
	Запись.УстановитьСтроку();
	ЗаписатьJSON(Запись, Тело);
	СтрокаJSON = Запись.Закрыть();

	Соединение = Новый HTTPСоединение("127.0.0.1", 8000);
	Запрос = Новый HTTPЗапрос("/api/jobs");
	Запрос.Заголовки.Вставить("Accept", "application/json");
	Запрос.Заголовки.Вставить("Accept-Encoding", "identity");
	Запрос.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Запрос.УстановитьТелоИзСтроки(СтрокаJSON, КодировкаТекста.UTF8);

	Ответ = Соединение.ОтправитьДляОбработки(Запрос);
	Если Ответ.КодСостояния <> 200 Тогда
		ВызватьИсключение "API ошибка: " + Строка(Ответ.КодСостояния) + " " + Ответ.ПолучитьТелоКакСтроку();
	КонецЕсли;

	JsonСтрока = Ответ.ПолучитьТелоКакСтроку();
	Чтение = Новый ЧтениеJSON;
	Чтение.УстановитьСтроку(JsonСтрока);
	ОтветСтрукт = ПрочитатьJSON(Чтение);

	Если ТипЗнч(ОтветСтрукт) <> Тип("Структура") Тогда
		Возврат "";
	КонецЕсли;

	Если ОтветСтрукт.Свойство("job_id") Тогда
		Возврат Строка(ОтветСтрукт["job_id"]);
	КонецЕсли;

	Возврат "";

КонецФункции

&НаСервере
Функция ВызватьAPI_GetJobResult_Post(JobId) Экспорт

	Тело = Новый Структура;
	Тело.Вставить("job_id", JobId);

	Запись = Новый ЗаписьJSON;
	Запись.УстановитьСтроку();
	ЗаписатьJSON(Запись, Тело);
	СтрокаJSON = Запись.Закрыть();

	Соединение = Новый HTTPСоединение("127.0.0.1", 8000);
	Запрос = Новый HTTPЗапрос("/api/jobs/result");
	Запрос.Заголовки.Вставить("Accept", "application/json");
	Запрос.Заголовки.Вставить("Accept-Encoding", "identity");
	Запрос.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Запрос.УстановитьТелоИзСтроки(СтрокаJSON, КодировкаТекста.UTF8);

	Ответ = Соединение.ОтправитьДляОбработки(Запрос);
	Если Ответ.КодСостояния <> 200 Тогда
		ВызватьИсключение "API ошибка: " + Строка(Ответ.КодСостояния) + " " + Ответ.ПолучитьТелоКакСтроку();
	КонецЕсли;

	JsonСтрока = Ответ.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8);
	Если ПустаяСтрока(JsonСтрока) Тогда
		ВызватьИсключение "Пустой ответ API";
	КонецЕсли;

	Чтение = Новый ЧтениеJSON;
	Чтение.УстановитьСтроку(JsonСтрока);
	Возврат ПрочитатьJSON(Чтение);

КонецФункции

&НаКлиенте
Функция ПолучитьРезультатJob_Post(JobId)

	ЛогК("Проверяю job_id=" + JobId);
	Ответ = ВызватьAPI_GetJobResult_Post(JobId);

	Если ТипЗнч(Ответ) <> Тип("Структура") Тогда
		ЛогК("Некорректный ответ Job API, тип=" + ТипЗнч(Ответ));
		Возврат Неопределено;
	КонецЕсли;

	Статус = "";
	Если Не Ответ.Свойство("status", Статус) Тогда
		ЛогК("Job API: отсутствует поле status.");
		Возврат Неопределено;
	КонецЕсли;

	ЛогК("job_id=" + JobId + " status=" + Статус);

	Если Статус = "done" Тогда
		Если Ответ.Свойство("result") Тогда
			Возврат Ответ["result"];
		Иначе
			JobIdИИ = "";
			Сообщить("Job done, но result отсутствует.");
			Возврат Неопределено;
		КонецЕсли;
	ИначеЕсли Статус = "error" Тогда
		Ош = "";
		Ответ.Свойство("error", Ош);
		JobIdИИ = "";
		Сообщить("Ошибка обработки: " + Ош);
		Возврат Неопределено;
	Иначе
		Сообщить("Статус: " + Статус);
		Возврат Неопределено;
	КонецЕсли;

КонецФункции
